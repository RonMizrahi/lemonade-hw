{
  "name": "onboarding-backend",
  "version": "0.1.0",
  "description": "Lemonade-style onboarding application — NestJS API + worker",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "start:worker": "node dist/main.worker.js",
    "start:worker:dev": "nest start --watch --entryFile main.worker",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --selectProjects unit",
    "test:integration": "jest --config jest.config.ts --selectProjects integration --runInBand",
    "test:e2e": "jest --config jest.config.ts --selectProjects e2e --runInBand",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "seed": "ts-node src/database/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/typeorm": "11.0.3",
    "@willsoto/nestjs-prometheus": "6.1.0",
    "bullmq": "5.80.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.4.1",
    "joi": "18.2.3",
    "nestjs-pino": "4.6.1",
    "pg": "8.22.0",
    "pino-http": "11.0.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.30",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@testcontainers/postgresql": "12.0.4",
    "@testcontainers/redis": "12.0.4",
    "@types/express": "5.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "22.10.5",
    "@types/supertest": "7.2.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "prettier": "3.9.5",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "testcontainers": "12.0.4",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  }
}
