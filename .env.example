# ── Onboarding App — environment reference ──────────────────────────────────
# Copy to `.env` and adjust. Every value here is validated at boot (backend/src/config).

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# API HTTP server
HTTP_PORT=3000
# Worker metrics server (M6)
WORKER_METRICS_PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=onboarding

# Redis (BullMQ — used by the worker from M4)
REDIS_HOST=localhost
REDIS_PORT=6379

# External-lookup pipeline (spec §7)
EXTERNAL_LOOKUP_MAX_TRIGGERS=3     # initial + manual retries before permanent failure
OUTBOX_POLL_INTERVAL_MS=500        # OutboxRelay poll cadence
LOOKUP_DELAY_MIN_MS=3000           # SimulatedPropertyService min delay
LOOKUP_DELAY_MAX_MS=8000           # SimulatedPropertyService max delay
LOOKUP_FAILURE_RATE=0.1            # ~10% simulated failure rate (0..1)
LOOKUP_JOB_ATTEMPTS=3              # BullMQ attempts per trigger

# Frontend (Vite dev proxy target)
VITE_API_URL=http://localhost:3000
